{
  "mcpServers": {
    "ynab": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@maro-org/ynab-mcp"],
      "env": {
        "YNAB_API_TOKEN": "${YNAB_API_TOKEN}",
        "YNAB_READ_ONLY": "true",
        "NODE_USE_ENV_PROXY": "1"
      }
    },
    "notion": {
      "type": "http",
      "url": "https://mcp.notion.com/mcp"
    }
  }
}